datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id       Int     @id @default(autoincrement())
  email    String? @unique
  username String? @unique
  password String
  apiKey   String @unique
  role     String @default("USER") // USER, ADMIN

  // Multi-tenancy Support
  parentId Int?
  parent   User?  @relation("UserToCompany", fields: [parentId], references: [id])
  agents   User[] @relation("UserToCompany")

  // Workspace Configurations
  defaultFunnelId       Int?
  defaultStageId        Int?
  aiDeactivationMinutes Int  @default(60)

  // Permissions & Features
  isActive         Boolean @default(true)
  metricsEnabled   Boolean @default(false)
  canManageUsers   Boolean @default(false)
  canEditTemplates Boolean @default(false)
  canExportData    Boolean @default(false)

  isCondoEnabled   Boolean @default(false)

  disabledMessage String?
  n8nWebhookUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  contacts         Contact[]
  funnels          Funnel[]
  messageTemplates MessageTemplate[]
  tags             Tag[]
  condominium      Condominium? // 1:1 Relation
}

model AdminMessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Funnel {
  id     Int     @id @default(autoincrement())
  name   String
  userId Int
  user   User    @relation(fields: [userId], references: [id])
  stages Stage[]
}

model Stage {
  id       Int       @id @default(autoincrement())
  name     String
  order    Int
  funnelId Int
  funnel   Funnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  contacts Contact[]
}

model Contact {
  id              Int       @id @default(autoincrement())
  phone           String
  name            String?
  userId          Int
  nameConfirmed   Boolean   @default(false)
  aiDisabledUntil DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  messages        Message[]
  stageId         Int?
  stage           Stage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)
  tags            Tag[]
  residents       Resident[]

  @@unique([userId, phone])
}

model Message {
  id            Int      @id @default(autoincrement())
  body          String
  timestamp     DateTime @default(now())
  status        String   @default("sent")
  direction     String
  fileUrl       String?
  fileType      String?
  fileName      String?
  isReadByAgent Boolean  @default(false)
  contactId     Int
  contact       Contact  @relation(fields: [contactId], references: [id])
  isFromIA      Boolean  @default(false)
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String
  color     String    @default("#3b82f6") // Default blue
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, name])
}

model Condominium {
  id          Int        @id @default(autoincrement())
  name        String     
  type        String     // 'CASA' o 'APARTAMENTO'
  userId      Int        @unique // Relación 1:1 (Un usuario, un único condominio)
  user        User       @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Configuraciones del Condominio (JSON)
  residentFields      String?
  incomeCategories   String?
  expenseCategories   String?
  fixedCosts          String?    // JSON: [{"name":"Vigilancia","amount":5000}]
  invoiceTemplate     String?    // JSON: PDF layout config (fonts, sizes, titles, item order)
  invoiceDay          Int        @default(1)
  paymentGraceDays    Int        @default(15) // Días de gracia para pagar

  residents        Resident[]
  transactions     Transaction[]
  logs             CondominiumLog[]
  invoices         Invoice[]
  residentDebts    ResidentDebt[]
  paymentMethods   PaymentMethod[]
}

model CondominiumLog {
  id             Int         @id @default(autoincrement())
  condominiumId  Int
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  action         String
  details        String?
  source         String
  createdAt      DateTime    @default(now())
}

model Invoice {
  id             Int         @id @default(autoincrement())
  condominiumId  Int
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  month          Int
  year           Int
  amount         Float
  lineItems      String?     // JSON: [{"concept":"Agua","amount":1200},...]
  notes          String?
  status         String      @default("PENDING")
  createdAt      DateTime    @default(now())
}

model Resident {
  id             Int         @id @default(autoincrement())
  name           String
  phone          String
  // Campos configurables extra almacenados como JSON
  additionalData String?     // JSON string
  
  condominiumId  Int
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  
  // Relacionar opcionalmente con un Contacto del CRM si existe un chat
  contactId      Int?
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Estado de solvencia
  status        String      @default("SOLVENTE")  // "SOLVENTE" o "INSOLVENTE"
  advanceCredit  Float       @default(0)            // Saldo a favor (pagos anticipados)

  transactions   Transaction[]
  residentDebts  ResidentDebt[]
  suggestions    ResidentSuggestion[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([condominiumId, phone]) // Un teléfono único por condominio
}

model Transaction {
  id               Int         @id @default(autoincrement())
  type             String      // 'INCOME' (Ingreso) o 'EXPENSE' (Egreso)
  category         String      // Ej: 'Pago', 'Cuotas especiales', 'Gastos fijos', 'Gastos extraordinarios'
  amount           Float
  description      String?
  status           String      @default("PENDING") // 'PENDING' (Por conciliar), 'RECONCILED' (Conciliado)
  date             DateTime    @default(now())
  isFixed          Boolean     @default(false) // Si es egreso fijo, se replica al mes siguiente
  source           String      @default("web")  // "api" o "web"
  
  // Soportes (Boucher / Recibo) - OBLIGATORIO
  receiptUrl       String?
  receiptType      String?     // mime type (pdf, jpeg, etc)
  
  // Mes y año que cancela (para pagos de meses específicos)
  month            Int?        // Mes que cancela (null = abono general)
  year             Int?        // Año que cancela
  
  // Método de pago
  paymentMethodId  Int?
  paymentMethod    PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  
  // Referencia del pago (mín 4 caracteres)
  reference        String?
  
  // Motivo de rechazo (mín 10 caracteres)
  rejectionReason  String?
  
  // Relaciones
  condominiumId  Int
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  
  // Sóo para ingresos (pagado por un residente)
  residentId     Int?
  resident       Resident?   @relation(fields: [residentId], references: [id], onDelete: SetNull)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model ResidentDebt {
  id             Int         @id @default(autoincrement())
  residentId     Int
  resident       Resident    @relation(fields: [residentId], references: [id], onDelete: Cascade)
  condominiumId Int
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  month          Int         // 1-12
  year           Int
  amount         Float       // Cuánto debe ese mes
  amountPaid     Float       @default(0) // Cuánto ha pagado de esa deuda
  invoiceId      Int?        // Referencia a la factura
  isPaid         Boolean     @default(false) // Si está totalmente pagado
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  @@unique([residentId, month, year])
}

model PaymentMethod {
  id            Int       @id @default(autoincrement())
  name          String    // ej: "Transferencia", "Pago Móvil", "Efectivo"
  fields        String    // JSON: [{"key": "banco", "label": "Banco"}]
  condominiumId Int
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  createdAt     DateTime  @default(now())
}

model ResidentSuggestion {
  id          Int       @id @default(autoincrement())
  residentId  Int
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type        String    // "SUGERENCIA" | "RECLAMO" | "OTRO"
  description String    // mín 10 caracteres
  status      String    @default("PENDIENTE") // "PENDIENTE", "EN_PROCESO", "ATENDIDA", "RECHAZADA"
  adminNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
