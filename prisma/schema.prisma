datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id       Int     @id @default(autoincrement())
  email    String? @unique
  username String? @unique
  password String
  apiKey   String @unique
  role     String @default("USER") // USER, ADMIN

  // Multi-tenancy Support
  parentId Int?
  parent   User?  @relation("UserToCompany", fields: [parentId], references: [id])
  agents   User[] @relation("UserToCompany")

  // Workspace Configurations
  defaultFunnelId       Int?
  defaultStageId        Int?
  aiDeactivationMinutes Int  @default(60)

  // Permissions & Features
  isActive         Boolean @default(true)
  metricsEnabled   Boolean @default(false)
  canManageUsers   Boolean @default(false)
  canEditTemplates Boolean @default(false)
  canExportData    Boolean @default(false)

  isCondoEnabled   Boolean @default(false)

  disabledMessage String?
  n8nWebhookUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  contacts         Contact[]
  funnels          Funnel[]
  messageTemplates MessageTemplate[]
  tags             Tag[]
  condominium      Condominium? // 1:1 Relation
}

model AdminMessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Funnel {
  id     Int     @id @default(autoincrement())
  name   String
  userId Int
  user   User    @relation(fields: [userId], references: [id])
  stages Stage[]
}

model Stage {
  id       Int       @id @default(autoincrement())
  name     String
  order    Int
  funnelId Int
  funnel   Funnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  contacts Contact[]
}

model Contact {
  id              Int       @id @default(autoincrement())
  phone           String
  name            String?
  userId          Int
  nameConfirmed   Boolean   @default(false)
  aiDisabledUntil DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  messages        Message[]
  stageId         Int?
  stage           Stage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)
  tags            Tag[]
  residents       Resident[]

  @@unique([userId, phone])
}

model Message {
  id            Int      @id @default(autoincrement())
  body          String
  timestamp     DateTime @default(now())
  status        String   @default("sent")
  direction     String
  fileUrl       String?
  fileType      String?
  fileName      String?
  isReadByAgent Boolean  @default(false)
  contactId     Int
  contact       Contact  @relation(fields: [contactId], references: [id])
  isFromIA      Boolean  @default(false)
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String
  color     String    @default("#3b82f6") // Default blue
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, name])
}

model Condominium {
  id          Int        @id @default(autoincrement())
  name        String     
  type        String     // 'CASA' o 'APARTAMENTO'
  userId      Int        @unique // Relación 1:1 (Un usuario, un único condominio)
  user        User       @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  residents   Resident[]
  transactions Transaction[]
}

model Resident {
  id             Int         @id @default(autoincrement())
  name           String
  phone          String
  // Campos configurables extra almacenados como JSON
  additionalData String?     // JSON string
  
  condominiumId  Int
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  
  // Relacionar opcionalmente con un Contacto del CRM si existe un chat
  contactId      Int?
  contact        Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  transactions   Transaction[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([condominiumId, phone]) // Un teléfono único por condominio
}

model Transaction {
  id             Int         @id @default(autoincrement())
  type           String      // 'INCOME' (Ingreso) o 'EXPENSE' (Egreso)
  category       String      // Ej: 'Pago', 'Cuotas especiales', 'Gastos fijos', 'Gastos extraordinarios'
  amount         Float
  description    String?
  status         String      @default("PENDING") // 'PENDING' (Por conciliar), 'RECONCILED' (Conciliado)
  date           DateTime    @default(now())
  
  // Soportes (Boucher / Recibo)
  receiptUrl     String?
  receiptType    String?     // mime type (pdf, jpeg, etc)
  
  // Relaciones
  condominiumId  Int
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  
  // Sólo para ingresos (pagado por un residente)
  residentId     Int?
  resident       Resident?   @relation(fields: [residentId], references: [id], onDelete: SetNull)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}
